# GCC lab AI department environment
# Copy these into your local Windows user/session environment. Do not commit real values.

# Optional CRM/Gmail bridge settings. Leave blank for local-only mode.
SWISS_PLANNER_USE_APPS_SCRIPT_BRIDGE=false
SWISS_PLANNER_WEBHOOK_URL=
SWISS_PLANNER_WEBHOOK_TOKEN=

# Optional local email sending. If SMTP is not configured, the local runtime creates .eml drafts.
SWISS_PLANNER_SMTP_HOST=
SWISS_PLANNER_SMTP_PORT=587
SWISS_PLANNER_SMTP_USER=
SWISS_PLANNER_SMTP_PASSWORD=
SWISS_PLANNER_SMTP_FROM=
SWISS_PLANNER_SMTP_USE_TLS=true

# Optional Manager Brain settings
SWISS_PLANNER_MANAGER_AI_ENABLED=true
SWISS_PLANNER_OPENAI_API_KEY=
SWISS_PLANNER_MANAGER_AI_MODEL=gpt-5-mini
SWISS_PLANNER_MANAGER_AI_REASONING_EFFORT=minimal

# Local app defaults
SWISS_PLANNER_COMMAND_CENTER_URL=http://127.0.0.1:8765/
AI_DEPARTMENT_HOST=127.0.0.1
AI_DEPARTMENT_PORT=8765
AI_DEPARTMENT_OPEN_BROWSER=true
AI_DEPARTMENT_DB_PATH=

# Optional Windmill execution backend. Keep real values only in .env.local or the OS environment.
WINDMILL_BASE_URL=
WINDMILL_WORKSPACE=
WINDMILL_TOKEN=
WINDMILL_MCP_URL=
WORLDBC_WORDPRESS_MAKE_WEBHOOK_URL=
